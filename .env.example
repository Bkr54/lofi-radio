# ------------------------------------------------------------------
# lofi-radio — environment configuration
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env && chmod 600 .env
# NEVER commit your real .env.
# ------------------------------------------------------------------

# Local HTTP port the dashboard listens on (proxied by nginx in production).
PORT=8080

# RTMP ingest endpoint. Default is YouTube Live.
STREAM_URL=rtmp://a.rtmp.youtube.com/live2

# Your secret stream key (YouTube Studio > Go Live > Stream key).
# Treat this like a password. It stays in .env only, never in the code/JSON.
STREAM_KEY=your_youtube_stream_key_here

# Session signing secret. Generate a random one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Dashboard login password, stored as a scrypt hash (never plaintext).
# Generate it with:  npm run set-password -- "YourStrongPassword"
# then paste the printed value here.
DASHBOARD_PASSWORD_HASH=

# Set to 1 when served over HTTPS (behind nginx). Use 0 for plain-HTTP local testing.
COOKIE_SECURE=0

# Streaming engine:
#   v2 = permanent/gapless single ffmpeg (0 reconnect between tracks) — recommended
#   v1 = restart ffmpeg per track (simplest, ~1 RTMP reconnect per track)
STREAM_ENGINE=v2

# Your public domain (used by the deploy templates: nginx + monitoring). Optional for the app itself.
DOMAIN=your-domain.example

# Optional: cut every track to N seconds (for quick demos/tests of the V2 engine). Leave unset in production.
# V2_TRACK_LIMIT_SEC=20
