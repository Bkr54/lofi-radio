{
  "name": "lofi-radio",
  "version": "1.0.0",
  "description": "Self-hosted 24/7 music radio streamer to YouTube (RTMP) with a web dashboard, Now Playing overlay, hot-swap playlists, a TV-grid scheduler and two streaming engines (per-track and gapless permanent).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "set-password": "node bin/set-password.js",
    "selftest": "node bin/v2-selftest.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "radio",
    "streaming",
    "youtube",
    "rtmp",
    "ffmpeg",
    "lofi",
    "24-7",
    "livestream"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/lofi-radio.git"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.14.2"
  }
}
